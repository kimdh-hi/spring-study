{
  "uid": "spring-monitoring",
  "title": "Spring Monitoring (LGTMP)",
  "tags": ["spring", "lgtmp"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Orders created (total)",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "sum(orders_created_total)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Orders created rate (1m)",
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "sum(rate(orders_created_total[1m]))",
          "legendFormat": "orders/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "HTTP request rate by uri (1m)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "{{uri}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "HTTP p95 latency",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "JVM heap used",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "heap"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{app=\"spring-monitoring\"}",
          "queryType": "range"
        }
      ],
      "options": { "showTime": true, "wrapLogMessage": true }
    }
  ]
}
